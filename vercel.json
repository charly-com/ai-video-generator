{
  "crons": [
    {
      "path": "/api/cron/publish",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/analytics-sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/token-refresh",
      "schedule": "0 */12 * * *"
    }
  ],
  "functions": {
    "src/app/api/generate/video/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/generate/image/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/publish/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/publish/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://viralkit.app"
        }
      ]
    }
  ]
}